DATABASE_URL="postgresql://finapp_user:your_db_password@localhost:5432/finapp?schema=public"
# PENTING: karakter $ di dalam hash bcrypt WAJIB di-escape dengan backslash (\$),
# karena loader env Next.js melakukan ekspansi variabel ($xx dianggap referensi variabel).
# Contoh: hash asli  $2b$12$abc...  ->  tulis sebagai  "\$2b\$12\$abc..."
APP_PASSWORD_HASH="\$2b\$12\$ganti_dengan_hash_asli_anda"
SESSION_SECRET="generate_random_32_byte_string"
NODE_ENV="production"
